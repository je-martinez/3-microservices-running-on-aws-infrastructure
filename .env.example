# .env.example — the committed contract for this repo's environment files.
#
# THIS FILE IS DOCUMENTATION, NOT CONFIG. Nothing loads it. Every real file
# below is generated by `make env-file` and git-ignored, because the values
# change on every `terraform apply`: Floci mints new Cognito ids and a new API
# id, and reassigns the RDS proxy ports by cluster creation order.
#
# GENERATED FILES AND THEIR CONSUMERS
#   .env                 the ONLY four vars docker-compose interpolates as ${VAR}
#   .env.local.infra     terraform outputs — read by the E2E suite and by humans
#   .env.local.users     Users service environment   (compose `env_file:`)
#   .env.local.orders    Orders service environment  (compose `env_file:`)
#   .env.local.debug     HOST-reachable connection strings; loaded by nothing
#
# EDITING RULE
# Each generated file has two boxes. `make env-file` rewrites ONLY the
# AUTO-GENERATED one; anything inside CUSTOM survives regeneration. Put your
# overrides and personal tokens in CUSTOM — never edit the AUTO box, it is
# overwritten without warning.
#
# ADDING A SERVICE
# Add a `.env.local.<service>` entry to the generator and an `env_file:` line to
# that service in docker-compose.yml. There is no shared services file: Users
# and Orders both define DATABASE_WRITER_URL with different values AND formats
# (a postgres:// URL versus an ADO connection string), so one file per service
# is what keeps them from colliding.


# ─── .env (root) ──────────────────────────────────────────────────────────────
# Only what docker-compose interpolates. A var referenced as ${VAR} in
# docker-compose.yml but absent here resolves to an EMPTY STRING, not an error —
# so a missing value fails silently. Keep this file minimal and complete.
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxx
USERS_DB_PORT=7001
ORDERS_DB_PORT=7002

# CUSTOM box — e.g. tooling tokens consumed by no service:
# APIDOG_ACCESS_TOKEN=
# APIDOG_PROJECT_ID=


# ─── .env.local.infra ─────────────────────────────────────────────────────────
# Terraform outputs. The E2E suite reads API_GATEWAY_URL from here.
# NOTE the literal `$default` path segment — it is Floci's REST API stage name,
# not a variable. The E2E config loads this with plain dotenv (no expansion)
# precisely so it survives verbatim.
API_GATEWAY_URL=http://localhost:4566/restapis/<api-id>/$default/_user_request_
USERS_DB_HOST=<floci-rds-proxy-ip>
ORDERS_DB_HOST=<floci-rds-proxy-ip>


# ─── .env.local.users ─────────────────────────────────────────────────────────
# AUTO-GENERATED half — reached by compose service name, on the discovered port.
AWS_ENDPOINT_URL=http://floci:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
DATABASE_WRITER_URL=postgres://test:test@floci:7001/users
DATABASE_READER_URL=postgres://test:test@floci:7001/users
GRPC_API_KEY=local-dev-grpc-key
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# Stated explicitly: the Node and .NET SDK defaults differ and a mismatch fails
# silently. Metrics/logs exporters are off — the collector serves traces only.
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# CUSTOM half — seeded once, then yours:
PORT=3000
GRPC_PORT=50051
WEBHOOK_SECRET=local-dev-secret


# ─── .env.local.orders ────────────────────────────────────────────────────────
# Same AWS/OTel values; the DB string is an ADO connection string, not a URL.
# SslMode=None because Floci's MySQL proxy terminates no TLS.
DATABASE_WRITER_URL=Server=floci;Port=7002;Database=orders;User=test;Password=test;SslMode=None;
DATABASE_READER_URL=Server=floci;Port=7002;Database=orders;User=test;Password=test;SslMode=None;
USERS_GRPC_URL=http://users:50051
OTEL_DIAGNOSTICS__LOGLEVEL=Error

# CUSTOM half:
SEED_ON_STARTUP=true


# ─── .env.local.debug ─────────────────────────────────────────────────────────
# HOST-reachable, for a SQL client running outside Docker. Loaded by no service:
# `localhost` inside a container would not resolve to Floci.
USERS_DATABASE_URL=postgres://test:test@localhost:7001/users
ORDERS_DATABASE_URL=mysql://test:test@localhost:7002/orders
