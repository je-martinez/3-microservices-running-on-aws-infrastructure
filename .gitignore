# Ignore all configuration settings, themes, and community plugins
.obsidian/

# Ignore system junk files
.trash/
.DS_Store

# Superpowers
.superpowers/

# Ministack local state & data (created at runtime by docker-compose)
/data/

# Node / pnpm
node_modules/
.pnpm-store/
# TypeScript build artifacts
dist/
**/dist/
# Env files (local secrets — never version)
.env
.env.*

# Playwright E2E artifacts
e2e/test-results/

# Terraform state & cache (local environments)
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
.terraform.lock.hcl

# Agent-skills CLI local mirror (canonical copies live in .claude/skills/)
.agents/
